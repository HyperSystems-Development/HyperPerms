{
  "name": "rpg",
  "displayName": "RPG Server",
  "description": "MMORPG-style server with classes and guilds",
  "version": "1.0.0",
  "author": "HyperPerms",
  "groups": {
    "default": {
      "permissions": [
        { "node": "hyperperms.command.check.self", "description": "Check own permissions" },
        { "node": "hytale.command.utility.help", "description": "View help" },
        { "node": "rpg.class.select", "description": "Select class" },
        { "node": "rpg.quest.view", "description": "View quests" },
        { "node": "rpg.quest.accept", "description": "Accept quests" },
        { "node": "rpg.party.join", "description": "Join parties" },
        { "node": "mmoskilltree.skill.*", "description": "Gain XP in all skills" },
        { "node": "mmoskilltree.command.xp", "description": "View XP stats" },
        { "node": "mmoskilltree.command.skilltree", "description": "Open skill tree" },
        { "node": "mmoskilltree.command.xpdisplay", "description": "Toggle XP display" }
      ],
      "weight": 0,
      "prefix": "&7",
      "suffix": ""
    },
    "adventurer": {
      "parents": ["default"],
      "permissions": [
        { "node": "rpg.party.create", "description": "Create parties" },
        { "node": "rpg.guild.join", "description": "Join guilds" },
        { "node": "rpg.dungeon.normal", "description": "Normal dungeons" },
        { "node": "mmoskilltree.xpboosts.all.self.1_25.15.30", "description": "Small personal XP boost (1.25x, 15min)" }
      ],
      "weight": 10,
      "prefix": "&a[Adventurer] ",
      "suffix": ""
    },
    "hero": {
      "parents": ["adventurer"],
      "permissions": [
        { "node": "rpg.guild.create", "description": "Create guilds" },
        { "node": "rpg.dungeon.hard", "description": "Hard dungeons" },
        { "node": "rpg.mount.basic", "description": "Basic mounts" },
        { "node": "mmoskilltree.xpboosts.all.self.1_5.30.120", "description": "Medium personal XP boost (1.5x, 30min)" }
      ],
      "weight": 20,
      "prefix": "&2[Hero] ",
      "suffix": ""
    },
    "champion": {
      "parents": ["hero"],
      "permissions": [
        { "node": "rpg.dungeon.legendary", "description": "Legendary dungeons" },
        { "node": "rpg.mount.epic", "description": "Epic mounts" },
        { "node": "rpg.title.custom", "description": "Custom titles" },
        { "node": "mmoskilltree.xpboosts.all.self.2_0.30.180", "description": "Large personal XP boost (2x, 30min)" }
      ],
      "weight": 30,
      "prefix": "&6[Champion] ",
      "suffix": ""
    },
    "legend": {
      "parents": ["champion"],
      "permissions": [
        { "node": "rpg.dungeon.*", "description": "All dungeons" },
        { "node": "rpg.mount.*", "description": "All mounts" },
        { "node": "rpg.cosmetic.*", "description": "All cosmetics" },
        { "node": "mmoskilltree.xpboosts.*.self.*", "description": "All personal XP boosts" }
      ],
      "weight": 40,
      "prefix": "&d[Legend] ",
      "suffix": ""
    },
    "gamemaster": {
      "parents": ["adventurer"],
      "permissions": [
        { "node": "hyperperms.command.check.others", "description": "Check others" },
        { "node": "rpg.admin.spawn", "description": "Spawn mobs" },
        { "node": "rpg.admin.quest", "description": "Quest management" },
        { "node": "mmoskilltree.command.setxp", "description": "Set player XP" },
        { "node": "mmoskilltree.command.quest", "description": "MMST quest management" }
      ],
      "weight": 60,
      "prefix": "&b[GM] ",
      "suffix": ""
    },
    "admin": {
      "parents": ["gamemaster"],
      "permissions": [
        { "node": "hyperperms.command.*", "description": "All perms commands" },
        { "node": "hytale.command.server.*", "description": "Server commands" },
        { "node": "rpg.admin.*", "description": "RPG admin" },
        { "node": "mmoskilltree.admin", "description": "MMOSkillTree admin" },
        { "node": "mmoskilltree.xpboosts.*", "description": "All XP boosts" }
      ],
      "weight": 90,
      "prefix": "&c[Admin] ",
      "suffix": ""
    },
    "owner": {
      "permissions": [
        { "node": "*", "description": "All permissions" }
      ],
      "weight": 100,
      "prefix": "&4[Owner] ",
      "suffix": ""
    }
  },
  "tracks": {
    "ranks": ["default", "adventurer", "hero", "champion", "legend"],
    "staff": ["gamemaster", "admin", "owner"]
  },
  "metadata": {
    "recommendedPlugins": ["MMOSkillTree"],
    "notes": "MMORPG server with classes, dungeons, and guilds"
  }
}
